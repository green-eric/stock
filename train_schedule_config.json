{
  "tasks": [
    {
      "id": "data_agent",
      "name": "数据采集Agent",
      "type": "process",
      "command": "python agents/data_agent.py",
      "interval": 300,
      "enabled": true,
      "description": "每5分钟收集市场数据",
      "working_dir": "."
    },
    {
      "id": "technical_agent",
      "name": "技术分析Agent",
      "type": "process",
      "command": "python agents/technical_agent.py",
      "interval": 900,
      "enabled": true,
      "description": "每15分钟分析股票技术指标",
      "working_dir": "."
    },
    {
      "id": "monitor_agent",
      "name": "系统监控Agent",
      "type": "process",
      "command": "python agents/monitor_agent_simple.py",
      "interval": 1800,
      "enabled": true,
      "description": "每30分钟监控系统状态",
      "working_dir": "."
    },
    {
      "id": "daily_skill_check",
      "name": "每日技能检查",
      "type": "script",
      "command": "bash check-skill-updates.sh",
      "schedule": "09:00",
      "enabled": true,
      "description": "每日09:00 UTC检查技能状态",
      "working_dir": "."
    },
    {
      "id": "daily_security_check",
      "name": "每日安全检查",
      "type": "script",
      "command": "bash quick-security-check.sh",
      "schedule": "08:00",
      "enabled": true,
      "description": "每日08:00快速安全检查",
      "working_dir": "."
    },
    {
      "id": "weekly_security_scan",
      "name": "每周安全扫描",
      "type": "script",
      "command": "bash skill-security-monitor.sh",
      "schedule": "mon 09:00",
      "enabled": true,
      "description": "每周一09:00完整安全扫描",
      "working_dir": "."
    }
  ],
  "settings": {
    "log_file": "logs/train_scheduler.log",
    "max_retries": 3,
    "retry_delay": 60,
    "health_check_interval": 300,
    "timezone": "Asia/Shanghai"
  }
}